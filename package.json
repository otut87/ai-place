{
  "name": "ai-place",
  "version": "0.1.0",
  "private": true,
  "browserslist": [
    "chrome >= 90",
    "firefox >= 90",
    "safari >= 15",
    "edge >= 90"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "npm run harness:check && next build && npx tsx scripts/validate-pages.ts",
    "build:only": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "harness:check": "tsx scripts/harness/check.ts",
    "harness:review": "tsx scripts/harness/record-review.ts",
    "harness:commit-msg": "tsx scripts/harness/hooks/commit-msg.ts",
    "migrate:blog": "tsx scripts/migrate-to-blog.ts",
    "migrate:blog:dry": "tsx scripts/migrate-to-blog.ts --dry-run",
    "migrate:blog:force": "tsx scripts/migrate-to-blog.ts --force",
    "seed:places": "tsx scripts/seed-places.ts",
    "baseline:test": "tsx scripts/baseline-test.ts",
    "indexnow": "tsx scripts/indexnow.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@base-ui/react": "^1.4.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "pretendard": "^1.3.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
