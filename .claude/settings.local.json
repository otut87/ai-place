{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/geo-seo-aeo-checklist.sh\"",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git -C /c/dev/ai-place config user.name)",
      "Bash(find /c/dev/ai-place/src -type f \\\\\\( -name \"*.tsx\" -o -name \"*.ts\" \\\\\\) -exec basename {} \\\\;)",
      "Skill(plan-eng-review)",
      "Skill(plan-eng-review:*)",
      "Skill(plan-design-review)",
      "Skill(plan-design-review:*)",
      "Bash(npm install:*)"
    ]
  },
