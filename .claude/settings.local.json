    },
    "fal-ai": {
      "disabled": true
    },
    "exa-web-search": {
      "disabled": true
    },
    "firecrawl": {
      "disabled": true
    },
    "browser-use": {
      "disabled": true
    },
    "memory": {
      "disabled": true
    },
    "magic": {
      "disabled": true
    },
    "cloudflare-docs": {
      "disabled": true
    },
    "cloudflare-observability": {
      "disabled": true
    },
    "cloudflare-workers-bindings": {
      "disabled": true
    },
    "cloudflare-workers-builds": {
      "disabled": true
    },
    "clickhouse": {
      "disabled": true
    },
    "railway": {
