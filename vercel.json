    "src/app/api/cron/pipeline-consume/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/blog-pipeline-consume/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/blog-perf-feedback/route.ts": { "maxDuration": 300 }
  }
