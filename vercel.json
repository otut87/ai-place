    { "path": "/api/cron/billing-expiry", "schedule": "30 1 * * *" },
    { "path": "/api/cron/pipeline-consume", "schedule": "*/5 * * * *" },
    { "path": "/api/cron/pipeline-enqueue-weekly", "schedule": "0 18 * * 6" },
    { "path": "/api/cron/autopublish-scheduled", "schedule": "0 * * * *" },
    { "path": "/api/cron/indexnow-daily", "schedule": "15 2 * * *" },
    { "path": "/api/cron/monthly-report", "schedule": "0 9 1 * *" },
    { "path": "/api/cron/trial-reminder", "schedule": "0 0 * * *" },
    { "path": "/api/cron/blog-keyword-refill", "schedule": "0 19 1 */3 *" },
    { "path": "/api/cron/blog-daily-planner", "schedule": "5 15 * * *" },
